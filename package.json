{
  "name": "urban-ease",
  "private": true,
  "scripts": {
    "install-all": "npm install && npm install --prefix server && npm install --prefix frontend",
    "start:server": "npm run dev --prefix Server",
    "start:client": "npm run dev --prefix Client ",
    "dev": "concurrently \"npm run start:server\" \"npm run start:client\""
  },
  "dependencies": {
    "express-flash": "^0.0.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
